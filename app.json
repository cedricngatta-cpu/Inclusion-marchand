{
  "expo": {
    "name": "Jùlaba",
    "slug": "inclusion-marchand-mobile",
    "version": "1.0.0",
    "sdkVersion": "54.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "scheme": "inclusion",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#C47316"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.inclusionmarchand.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "monochromeImage": "./assets/android-icon-monochrome.png",
        "backgroundColor": "#C47316"
      },
      "splash": {
        "image": "./assets/splash-icon.png",
        "resizeMode": "contain",
        "backgroundColor": "#C47316"
      },
      "softwareKeyboardLayoutMode": "pan",
      "package": "com.inclusionmarchand.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#C47316",
          "image": "./assets/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "android": {
            "backgroundColor": "#C47316",
            "image": "./assets/splash-icon.png",
            "imageWidth": 200,
            "resizeMode": "contain"
          }
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Autoriser Jùlaba à accéder à la caméra pour scanner les codes-barres et prendre des photos."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Autoriser Jùlaba à accéder à vos photos pour les images produits.",
          "cameraPermission": "Autoriser Jùlaba à utiliser la caméra pour photographier les produits."
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "Autoriser Jùlaba à utiliser le microphone pour l'assistant vocal."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "1aa3b398-083a-4b58-9ef8-5408a0f10b98"
      }
    }
  }
}
